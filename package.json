{
  "name": "lean-theorem-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based Lean 4 playground with Mathlib, local AI tutoring, and proof-to-document export.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "pages-preview": "npx http-server docs -p 4173 -c-1"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.83",
    "@tanstack/react-query": "^5.90.7",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.468.0",
    "markdown-it": "^14.1.0",
    "pandoc-wasm": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.5"
  }
}

